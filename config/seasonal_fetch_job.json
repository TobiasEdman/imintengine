{
    "conditions": {
        "colonyname": "imint",
        "executortype": "container-executor"
    },
    "env": {
        "EASTING": "",
        "NORTHING": "",
        "WEST_WGS84": "",
        "SOUTH_WGS84": "",
        "EAST_WGS84": "",
        "NORTH_WGS84": "",
        "FETCH_SOURCE": "copernicus",
        "YEARS": "2019,2018",
        "SEASONAL_WINDOWS": "4-5,6-7,8-9,1-2",
        "SEASONAL_CLOUD_THRESHOLD": "0.10",
        "TILES_DIR": "/cfs/tiles",
        "NUM_CLASSES": "10",
        "B02_HAZE_THRESHOLD": "0.06",
        "DES_TOKEN": "",
        "CDSE_CLIENT_ID": "",
        "CDSE_CLIENT_SECRET": ""
    },
    "funcname": "seasonal-tile-fetch",
    "kwargs": {
        "docker-image": "imint-engine:latest",
        "rebuild-image": false,
        "cmd": "executors/seasonal_fetch.py"
    },
    "maxexectime": 900,
    "maxretries": 3,
    "fs": [
        {
            "mount": "/cfs/tiles",
            "dir": "seasonal-tiles",
            "keepfiles": true
        }
    ]
}
