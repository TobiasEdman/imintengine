# IMINT Engine — Environment Configuration Template
# Copy to dev.env / test.env / prod.env and fill in values.
# These files are gitignored (secrets must not be committed).
#
# Usage:
#   IMINT_ENV=dev make train-dev
#   IMINT_ENV=test python scripts/train_lulc.py --epochs 2

# ── Environment ────────────────────────────────────────────
IMINT_ENV=dev                    # dev | test | prod

# ── Authentication (required for data fetching) ───────────
DES_USER=
DES_PASSWORD=
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# ── Skogsstyrelsen aux data endpoints ─────────────────────
SKG_HEIGHT_URL=
SKG_GRUNDDATA_URL=

# ── Training ──────────────────────────────────────────────
IMINT_BATCH_SIZE=8
IMINT_NUM_WORKERS=4
IMINT_DEVICE=                    # mps | cuda | cpu (auto-detect if empty)
IMINT_EPOCHS=50
IMINT_DATA_DIR=~/training_data
IMINT_OUTPUT_DIR=outputs

# ── ColonyOS ──────────────────────────────────────────────
COLONIES_SERVER_HOST=localhost
COLONIES_SERVER_PORT=50080
COLONIES_TLS=false
