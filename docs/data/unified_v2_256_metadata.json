{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "dataset": {
    "id": "imint-unified-v2-256",
    "name": "ImintEngine Unified v5 — 256 px multitemporal training tiles",
    "description": "Multitemporal Sentinel-2 + auxiliary geospatial tiles over Sweden for 23-class LULC + harvest-readiness segmentation (Prithvi-EO-2.0). Each tile bundles 4 temporal frames of 6-band reflectance plus a deep auxiliary stack (forest metrics, DEM, VPP phenology, harvest probability, optional red-edge / Sentinel-1 / Tessera embeddings) and the unified label raster.",
    "schema_version": "v5",
    "n_tiles": 8290,
    "tile_format": "npz",
    "approx_total_size_gb": 168,
    "approx_tile_size_mb": 22,
    "license": "Derived from open data (ESA Copernicus Sentinel-2, Naturvårdsverket NMD, Jordbruksverket LPIS/SJV, Skogsstyrelsen SKS, SLU, Lantmäteriet/Copernicus DEM). Redistribution subject to the respective source licenses.",
    "produced_by": "imint/training/fetch_unified_tiles.py + scripts/build_labels.py"
  },
  "spatial": {
    "crs": "EPSG:3006",
    "crs_name": "SWEREF99 TM",
    "gsd_m": 10,
    "tile_px": 256,
    "tile_extent_m": 2560,
    "tiling": "center-based; bbox derived from (easting, northing) tile center via bbox_from_center(size_px=256)",
    "bbox_order": "[west, south, east, north]"
  },
  "temporal": {
    "num_frames": 4,
    "num_bands": 6,
    "band_order": ["B02", "B03", "B04", "B8A", "B11", "B12"],
    "band_note": "Prithvi-EO-2.0 6-band order. NIR is B8A (20 m), NOT B08.",
    "frame_strategy": "Frame 0 = autumn (Sep–Oct) of year-1 (stubble / winter crops). Frames 1–3 = VPP-phenology-guided growing-season windows, adapted per tile latitude.",
    "value_space": "surface reflectance, float32, nominal range ~[0.0, 0.4]; feed raw reflectance to models (do NOT percentile-stretch)",
    "example_dates": ["2021-09-09", "2022-04-22", "2022-08-12", "2022-10-19"],
    "label_year_matching": "Spectral year MUST match the label year (LPIS/SKS). Autumn frame is from label-year minus 1."
  },
  "label_schema": {
    "num_classes": 23,
    "ignore_index": 0,
    "classes": [
      {"id": 0,  "name": "bakgrund",            "source": "—",   "note": "ignore_index"},
      {"id": 1,  "name": "tallskog",            "source": "NMD"},
      {"id": 2,  "name": "granskog",            "source": "NMD"},
      {"id": 3,  "name": "lövskog",             "source": "NMD"},
      {"id": 4,  "name": "blandskog",           "source": "NMD"},
      {"id": 5,  "name": "sumpskog",            "source": "NMD"},
      {"id": 6,  "name": "tillfälligt ej skog", "source": "NMD"},
      {"id": 7,  "name": "våtmark",             "source": "NMD"},
      {"id": 8,  "name": "öppen mark",          "source": "NMD"},
      {"id": 9,  "name": "bebyggelse",          "source": "NMD"},
      {"id": 10, "name": "vatten",              "source": "NMD"},
      {"id": 11, "name": "vete",                "source": "LPIS", "sjv_codes": [4, 5, 29, 307]},
      {"id": 12, "name": "korn",                "source": "LPIS", "sjv_codes": [1, 2, 12, 13, 315]},
      {"id": 13, "name": "havre",               "source": "LPIS", "sjv_codes": [3]},
      {"id": 14, "name": "oljeväxter",          "source": "LPIS", "sjv_codes": [20, 21, 22, 23, 24, 25, 26, 27, 28, 38, 40]},
      {"id": 15, "name": "slåttervall",         "source": "LPIS", "sjv_codes": [49, 50, 57, 58, 59, 62, 302]},
      {"id": 16, "name": "bete",                "source": "LPIS", "sjv_codes": [52, 53, 54, 55, 56, 61, 89, 90, 95]},
      {"id": 17, "name": "potatis",             "source": "LPIS", "sjv_codes": [45, 46, 311]},
      {"id": 18, "name": "sockerbetor",         "source": "LPIS", "sjv_codes": [47, 48]},
      {"id": 19, "name": "trindsäd",            "source": "LPIS", "sjv_codes": [30, 31, 32, 33, 34, 35, 36, 37, 39, 43]},
      {"id": 20, "name": "råg",                 "source": "LPIS", "sjv_codes": [7, 8, 29, 317]},
      {"id": 21, "name": "majs",                "source": "LPIS", "sjv_codes": [9]},
      {"id": 22, "name": "hygge",               "source": "SKS",  "note": "harvest within 5 years before tile year"}
    ]
  },
  "model_input": {
    "description": "Prithvi-EO-2.0 input is (4 frames × 6 bands + 10 aux, H, W) = 34 channels. (The synthetic harvest_probability channel was dropped — it leaked the harvest target into the input.)",
    "channels": 34,
    "spectral_channels": 24,
    "aux_channels_10": ["height", "volume", "basal_area", "diameter", "dem", "vpp_sosd", "vpp_eosd", "vpp_length", "vpp_maxv", "vpp_minv"],
    "heads": {
      "lulc": "23-class softmax segmentation (focal loss)",
      "harvest_ready": "binary sigmoid harvest-readiness map (BCE loss), trained where n_mature_polygons > 0"
    }
  },
  "arrays": {
    "_note": "H = W = 256. Optional arrays may be absent in some tiles; check the paired has_* / presence flag. Reflectance arrays are float32 surface reflectance.",
    "image":               {"shape": [24, "H", "W"], "dtype": "float32", "desc": "4 frames × 6 bands spectral reflectance (Prithvi band order)", "source": "Sentinel-2 L2A", "required": true},
    "spectral":            {"shape": [24, "H", "W"], "dtype": "float32", "desc": "alias of `image` (newer key name); identical content", "source": "Sentinel-2 L2A", "required": true},
    "label":               {"shape": ["H", "W"], "dtype": "uint8", "desc": "23-class unified label (0 = bakgrund / ignore)", "source": "NMD + LPIS + SKS", "required": true},
    "label_mask":          {"shape": ["H", "W"], "dtype": "uint16", "desc": "rasterized raw LPIS/SJV grödkod mask (uint16) before unified mapping", "source": "LPIS", "required": false},
    "nmd_label":           {"shape": ["H", "W"], "dtype": "uint8", "desc": "NMD-derived unified class (0–10)", "source": "NMD", "required": false},
    "nmd_label_raw":       {"shape": ["H", "W"], "dtype": "uint8", "desc": "NMD passed through nmd_raster_to_lulc (range 0–19); NOT the raw .tif codes", "source": "NMD", "required": false},
    "dem":                 {"shape": ["H", "W"], "dtype": "float32", "desc": "elevation (m)", "source": "Copernicus DEM", "required": false},
    "height":              {"shape": ["H", "W"], "dtype": "float32", "desc": "forest canopy height (m)", "source": "SLU Skogliga grunddata", "required": false},
    "volume":              {"shape": ["H", "W"], "dtype": "float32", "desc": "stem volume (m³/ha)", "source": "SLU Skogliga grunddata", "required": false},
    "basal_area":          {"shape": ["H", "W"], "dtype": "float32", "desc": "basal area (m²/ha)", "source": "SLU Skogliga grunddata", "required": false},
    "diameter":            {"shape": ["H", "W"], "dtype": "float32", "desc": "mean stem diameter (cm)", "source": "SLU Skogliga grunddata", "required": false},
    "vpp_sosd":            {"shape": ["H", "W"], "dtype": "float32", "desc": "start-of-season day", "source": "Copernicus HR-VPP", "required": false},
    "vpp_eosd":            {"shape": ["H", "W"], "dtype": "float32", "desc": "end-of-season day", "source": "Copernicus HR-VPP", "required": false},
    "vpp_length":          {"shape": ["H", "W"], "dtype": "float32", "desc": "season length (days)", "source": "Copernicus HR-VPP", "required": false},
    "vpp_maxv":            {"shape": ["H", "W"], "dtype": "float32", "desc": "seasonal max vegetation index", "source": "Copernicus HR-VPP", "required": false},
    "vpp_minv":            {"shape": ["H", "W"], "dtype": "float32", "desc": "seasonal min vegetation index", "source": "Copernicus HR-VPP", "required": false},
    "harvest_mask":        {"shape": ["H", "W"], "dtype": "uint8", "desc": "binary mask of SKS executed-harvest (utförd avverkning) polygons", "source": "SKS", "required": false},
    "markfukt":            {"shape": ["H", "W"], "dtype": "float32", "desc": "soil moisture index (markfuktighet)", "source": "SLU", "required": false},
    "nmd_area_ha":         {"shape": ["H", "W"], "dtype": "float32", "desc": "NMD object area (ha)", "source": "NMD", "required": false},
    "parcel_area_ha":      {"shape": ["H", "W"], "dtype": "float32", "desc": "LPIS parcel area (ha)", "source": "LPIS", "required": false},
    "rededge":             {"shape": [12, "H", "W"], "dtype": "float32", "desc": "red-edge bands (B05/B06/B07) across frames", "source": "Sentinel-2 L2A", "required": false, "presence_flag": "has_rededge"},
    "s1_vv_vh":            {"shape": [8, "H", "W"], "dtype": "float32", "desc": "Sentinel-1 VV/VH backscatter across frames", "source": "Sentinel-1 GRD", "required": false, "presence_flag": "has_s1"},
    "tessera":             {"shape": [128, "H", "W"], "dtype": "float16", "desc": "Tessera foundation-model embedding (128-dim)", "source": "Tessera", "required": false, "presence_flag": "has_tessera"},
    "frame_2016":          {"shape": [6, "H", "W"], "dtype": "float32", "desc": "legacy 2016 single autumn frame (6 bands)", "source": "Sentinel-2 L2A", "required": false, "presence_flag": "has_frame_2016"}
  },
  "scalars": {
    "point_id":           {"dtype": "str",   "desc": "tile id (matches legacy filename stem)"},
    "label_name":         {"dtype": "str",   "desc": "legacy per-tile dominant-label name"},
    "lat":                {"dtype": "float64", "desc": "tile-center latitude (WGS84)"},
    "lon":                {"dtype": "float64", "desc": "tile-center longitude (WGS84)"},
    "easting":            {"dtype": "int64", "desc": "tile-center easting (EPSG:3006)"},
    "northing":           {"dtype": "int64", "desc": "tile-center northing (EPSG:3006)"},
    "bbox_3006":          {"dtype": "int64[4]", "desc": "[west, south, east, north] in EPSG:3006"},
    "tile_size_px":       {"dtype": "int32", "desc": "256"},
    "lpis_year":          {"dtype": "int32", "desc": "label year (LPIS); spectral matches this year"},
    "num_frames":         {"dtype": "int32", "desc": "4"},
    "num_bands":          {"dtype": "int32", "desc": "6"},
    "multitemporal":      {"dtype": "int32", "desc": "1 if multitemporal stack present"},
    "vpp_guided":         {"dtype": "bool",  "desc": "True if frames 1–3 were VPP-phenology-guided"},
    "dates":              {"dtype": "str[4]", "desc": "acquisition date per frame (YYYY-MM-DD)"},
    "doy":                {"dtype": "int32[4]", "desc": "day-of-year per frame"},
    "temporal_mask":      {"dtype": "uint8[4]", "desc": "1 = frame present/valid, 0 = missing"},
    "n_parcels":          {"dtype": "int32", "desc": "LPIS parcels intersecting the tile"},
    "n_harvest_polygons": {"dtype": "int32", "desc": "SKS harvest polygons intersecting the tile"},
    "n_mature_polygons":  {"dtype": "int32", "desc": "harvest-ready polygons (head-2 positive supervision)"}
  },
  "file_naming": {
    "schemes": {
      "coordinate": {
        "patterns": [
          "tile_<east>_<north>.npz  (LULC grid)",
          "crop_<crop>_<east>_<north>.npz  (LPIS crop centroid)",
          "urban_<east>_<north>.npz  (SCB tätort)"
        ],
        "encodes": "EPSG:3006 tile-center easting_northing"
      },
      "point_id": {
        "patterns": ["<point_id>.npz  (e.g. 43983928.npz)"],
        "encodes": "legacy LUCAS-style point id; coords are stored inside the .npz, not in the name"
      }
    },
    "note": "All tiles share one flat directory; crop_/urban_ are name prefixes, not folders. Every tile also stores easting/northing/bbox_3006 internally.",
    "split_caveat": "The train/val/test split is md5(filename) % 100 (val < 10; test by latitude), so the filename determines the split. Do NOT rename tiles — it reshuffles the split. New builds should use <type>_<east>_<north>.npz.",
    "recommended_new_form": "<type>_<east>_<north>.npz"
  },
  "model": {
    "name": "Prithvi-EO-2.0 300M — unified v5 256px baseline",
    "backbone": "prithvi_eo_v2_300m_tl",
    "num_temporal_frames": 4,
    "in_channels": 35,
    "num_classes": 23,
    "epochs": 10,
    "batch_size": 4,
    "lr": 0.0001,
    "val_miou": 0.4716,
    "status": "baseline (fine-tuning seed; not production)",
    "note": "Trained with 35 input channels (incl. the harvest_probability aux). That synthetic channel has since been dropped from the dataset (now 34ch); retrain or adapt the input stem accordingly.",
    "files": {
      "checkpoint": "model/prithvi_300m_256_best.pt",
      "training_log": "model/training_log.json",
      "card": "model/MODEL_CARD.md"
    }
  },
  "access": {
    "download_url": "https://dataset-256.icedc.se/unified_v2/",
    "metadata_url": "https://dataset-256.icedc.se/metadata.json",
    "availability": "temporary (~48h) ICE-hosted directory listing",
    "auth": "HTTP basic-auth required (credentials shared separately)",
    "listing_note": "The listing shows only the .npz tiles plus useful bookkeeping files (class_stats.json, manifest.json, splits_summary.json, train/val/test.txt). crop_*/urban_* are flat-named tile prefixes, not folders.",
    "loader_hint": "numpy.load(path, allow_pickle=True); train/val split is a deterministic md5(filename) % 100 < 10 → val."
  }
}
